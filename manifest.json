{
  "manifest_version": 3,
  "name": "AI Helper",
  "version": "7.0",
  "description": "Smart AI-powered browser assistant",
  "permissions": [
    "scripting",
    "activeTab",
    "cookies",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://discord.com/*",
    "https://api.groq.com/*",
    "https://www.roblox.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["config.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
